{
	"name": "hls-distrib",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepare-theme": "npm run smui-theme-light && npm run smui-theme-dark",
		"smui-theme-light": "smui-theme compile static/smui.css -i src/theme",
		"smui-theme-dark": "smui-theme compile static/smui-dark.css -i src/theme/dark",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@material/typography": "^14.0.0",
		"@smui-extra/badge": "^8.0.3",
		"@smui-extra/chip-input": "^8.0.3",
		"@smui/button": "^8.0.3",
		"@smui/card": "^8.0.3",
		"@smui/chips": "^8.0.3",
		"@smui/circular-progress": "^8.0.3",
		"@smui/data-table": "^8.0.3",
		"@smui/dialog": "^8.0.3",
		"@smui/drawer": "^8.0.3",
		"@smui/fab": "^8.0.3",
		"@smui/icon-button": "^8.0.3",
		"@smui/list": "^8.0.3",
		"@smui/menu": "^8.0.3",
		"@smui/paper": "^8.0.3",
		"@smui/select": "^8.0.3",
		"@smui/snackbar": "^8.0.3",
		"@smui/textfield": "^8.0.3",
		"@smui/top-app-bar": "^8.0.3",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"smui-theme": "^8.0.3",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1"
	}
}
